<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.*?>
<BorderPane xmlns="http://javafx.com/javafx/19.0.2.1" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.biblio.controller.MembersController">
    <center>
        <TableView fx:id="table" onMouseClicked="#onSelect">
            <columns>
                <TableColumn fx:id="colMatricule" text="Matricule" prefWidth="120"/>
                <TableColumn fx:id="colNom" text="Nom" prefWidth="140"/>
                <TableColumn fx:id="colPrenom" text="Prénom" prefWidth="140"/>
                <TableColumn fx:id="colEmail" text="Email" prefWidth="180"/>
                <TableColumn fx:id="colActif" text="Actif" prefWidth="60"/>
            </columns>
        </TableView>
    </center>
    <bottom>
        <GridPane hgap="8" vgap="8">
            <padding>
                <Insets top="10" right="10" bottom="10" left="10"/>
            </padding>
            <Label text="Matricule" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
            <TextField fx:id="matriculeField" GridPane.rowIndex="0" GridPane.columnIndex="1"/>
            <Label text="Nom" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
            <TextField fx:id="nomField" GridPane.rowIndex="1" GridPane.columnIndex="1"/>
            <Label text="Prénom" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
            <TextField fx:id="prenomField" GridPane.rowIndex="2" GridPane.columnIndex="1"/>
            <Label text="Email" GridPane.rowIndex="0" GridPane.columnIndex="2"/>
            <TextField fx:id="emailField" GridPane.rowIndex="0" GridPane.columnIndex="3"/>
            <Label text="Téléphone" GridPane.rowIndex="1" GridPane.columnIndex="2"/>
            <TextField fx:id="telephoneField" GridPane.rowIndex="1" GridPane.columnIndex="3"/>
            <Label text="Adresse" GridPane.rowIndex="2" GridPane.columnIndex="2"/>
            <TextField fx:id="adresseField" GridPane.rowIndex="2" GridPane.columnIndex="3"/>
            <CheckBox fx:id="actifCheck" text="Actif" GridPane.rowIndex="3" GridPane.columnIndex="1"/>
            <HBox spacing="8" alignment="CENTER_RIGHT" GridPane.rowIndex="3" GridPane.columnIndex="3">
                <Button text="Nouveau" onAction="#onNew"/>
                <Button text="Enregistrer" onAction="#onSave"/>
                <Button text="Réinitialiser" onAction="#onReset"/>
                <Button text="Historique" onAction="#onHistory"/>
                <Button text="Accueil" onAction="#onBack"/>
            </HBox>
        </GridPane>
    </bottom>
</BorderPane>
